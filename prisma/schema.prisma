generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  name           String?
  avatar         String?
  passwordHash   String?
  role           String    @default("USER") // USER | STAFF | ADMIN
  isPremium      Boolean   @default(false)
  premiumUntil   DateTime?
  tokens         Int       @default(30)
  lives          Int       @default(5)
  livesLastRegen DateTime  @default(now())
  referralCode   String    @unique @default(cuid())
  referredBy     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  practiceSessions PracticeSession[]
  savedItems       SavedItem[]
  lessonProgress   LessonProgress[]
  referrals        Referral[]   @relation("ReferrerReferrals")
  streaks          Streak[]
  sharedAnswers    SharedAnswer[]
  paymentOrders    PaymentOrder[]
  customLessons    CustomLesson[]
  stageTestResults StageTestResult[]
}

model PaymentOrder {
  id        String   @id @default(cuid())
  orderCode Int      @unique
  userId    String
  months    Int
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum SessionType {
  BEGINNER
  PRACTICE
  MOCK_TEST
}

enum IELTSPart {
  PART1
  PART2
  PART3
  FULL
}

enum SavedType {
  VOCABULARY
  IDIOM
  SAMPLE_ANSWER
}

model PracticeSession {
  id        String      @id @default(cuid())
  userId    String
  type      SessionType
  topic     String
  part      IELTSPart?
  questions Json
  scores    Json
  duration  Int         @default(0)
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedItem {
  id        String    @id @default(cuid())
  userId    String
  type      SavedType
  content   String
  context   String?
  topic     String?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  completed   Boolean   @default(false)
  score       Int?
  completedAt DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Referral {
  id          String   @id @default(cuid())
  referrerId  String
  refereeId   String   @unique
  hasUsedApp  Boolean  @default(false)
  rewardGiven Boolean  @default(false)
  createdAt   DateTime @default(now())
  referrer    User     @relation("ReferrerReferrals", fields: [referrerId], references: [id], onDelete: Cascade)
}

model Streak {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  practiced Boolean  @default(true)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// Custom lessons created by admin (stored fully in DB, not in lessons-data.ts)
model CustomLesson {
  id          String   @id @default(cuid())
  stageId     String
  title       String
  type        String   // vocabulary | grammar | speaking
  topic       String
  level       String   // A1 | A2 | B1 | B2
  description String   @default("")
  xp          Int      @default(50)
  cards       Json
  order       Int      @default(0)
  published   Boolean  @default(false)
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Admin-managed lesson content overrides (replaces static data in lib/lessons-data.ts)
model LessonContent {
  id        String   @id @default(cuid())
  lessonId  String   @unique
  data      Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model StageTestResult {
  id        String   @id @default(cuid())
  userId    String
  stageId   String
  passed    Boolean
  score     Int
  livesLeft Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, stageId])
}

model Stage {
  id          String   @id @default(cuid())
  title       String
  subtitle    String
  icon        String   @default("📚")
  color       String   @default("from-cyan-500 to-blue-600")
  accentColor String   @default("cyan")
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChatWidgetSession {
  id          String    @id @default(cuid())
  userId      String?
  userName    String?
  userEmail   String?
  source      String?
  messages    Json      // [{ role: 'bot'|'user', content: string, ts: number }]
  adminReply  String?   @db.Text
  repliedAt   DateTime?
  status      String    @default("OPEN") // OPEN | RESOLVED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SharedAnswer {
  id          String     @id @default(cuid())
  userId      String
  question    String
  transcript  String     @db.Text
  audioUrl    String?    @db.Text
  score       Json
  band        Float
  topic       String
  part        IELTSPart
  isAnonymous Boolean    @default(false)
  likes       Int        @default(0)
  createdAt   DateTime   @default(now())
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}
